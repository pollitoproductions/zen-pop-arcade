# Keystore Configuration Template
# 
# Copy this file to keystore.properties and fill in with your actual credentials
# DO NOT commit this file to version control with real passwords!
#
# Generate a keystore with:
# keytool -genkey -v -keystore keystore.jks -keyalg RSA -keysize 2048 -validity 10000 -alias android

storeFile=keystore.jks
storePassword=YOUR_KEYSTORE_PASSWORD
keyAlias=android
keyPassword=YOUR_KEY_PASSWORD
